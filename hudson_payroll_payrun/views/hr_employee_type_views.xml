<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View for Employee Type -->
    <record id="hr_employee_type_view_tree" model="ir.ui.view">
        <field name="name">hr.employee.type.view.list</field>
        <field name="model">hr.employee.type</field>
        <field name="arch" type="xml">
            <list string="Employee Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Inherit Employee Form View to add Employee Type & Bank Account -->
    <record id="hr_employee_view_form_inherit_payrun" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit.payrun</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="employee_type_id" options="{'no_create': True}"/>
                <field name="bank_account_id"/>
            </xpath>
        </field>
    </record>

    <!-- Window Action for Employee Type -->
    <record id="hr_employee_type_action" model="ir.actions.act_window">
        <field name="name">Employee Types</field>
        <field name="res_model">hr.employee.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menuitem for Employee Type -->
    <menuitem id="menu_hr_employee_type"
              name="Employee Types"
              action="hr_employee_type_action"
              parent="hr_payroll_community.menu_hr_payroll_community_configuration"
              sequence="25"/>

</odoo>
