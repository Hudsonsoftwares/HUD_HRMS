<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sequence for Payment Advice -->
    <record id="seq_hudson_payroll_payment_advice" model="ir.sequence">
        <field name="name">Payment Advice</field>
        <field name="code">hudson.payroll.payment.advice</field>
        <field name="prefix">PA/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Form View for Payment Advice -->
    <record id="hudson_payment_advice_view_form" model="ir.ui.view">
        <field name="name">hudson.payroll.payment.advice.view.form</field>
        <field name="model">hudson.payroll.payment.advice</field>
        <field name="arch" type="xml">
            <form string="Payment Advice">
                <header>
                    <button name="action_confirm" type="object" string="Confirm Advice"
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_export_csv" type="object" string="Export Bank CSV"
                            class="oe_highlight" icon="fa-download"/>
                    <button name="%(hudson_payroll_payrun.action_report_payment_advice)d" type="action" string="Print PDF Advice"
                            icon="fa-print"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Run &amp; Bank Details">
                            <field name="payslip_run_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="company_bank_id" readonly="state != 'draft'"/>
                        </group>
                        <group string="Summary">
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="total_amount" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employee Payment Lines" name="payment_lines">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list string="Payment Lines" decoration-danger="not has_bank_account" editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="bank_name"/>
                                    <field name="acc_number"/>
                                    <field name="ifsc_code"/>
                                    <field name="net_amount" sum="Total Net Amount"/>
                                    <field name="has_bank_account" widget="boolean_toggle" string="Bank Recorded"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Add internal notes or bank transfer instructions..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Tree View for Payment Advice -->
    <record id="hudson_payment_advice_view_tree" model="ir.ui.view">
        <field name="name">hudson.payroll.payment.advice.view.list</field>
        <field name="model">hudson.payroll.payment.advice</field>
        <field name="arch" type="xml">
            <list string="Payment Advices">
                <field name="name"/>
                <field name="payslip_run_id"/>
                <field name="date"/>
                <field name="company_bank_id"/>
                <field name="total_amount" sum="Total Disbursed"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Window Action for Payment Advice -->
    <record id="hudson_payment_advice_action" model="ir.actions.act_window">
        <field name="name">Payment Advices</field>
        <field name="res_model">hudson.payroll.payment.advice</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menuitem for Payment Advice -->
    <menuitem id="menu_hudson_payment_advice"
              name="Payment Advices"
              action="hudson_payment_advice_action"
              parent="hr_payroll_community.menu_hr_payroll_community_root"
              sequence="20"/>

</odoo>
