<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pivot View -->
    <record id="hr_payslip_line_view_pivot" model="ir.ui.view">
        <field name="name">hr.payslip.line.view.pivot</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <pivot string="Payslip Lines Analysis">
                <field name="employee_id" type="row"/>
                <field name="code" type="col"/>
                <field name="total" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="hr_payslip_line_view_graph" model="ir.ui.view">
        <field name="name">hr.payslip.line.view.graph</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <graph string="Payslip Lines Analysis" type="bar">
                <field name="employee_id" type="row"/>
                <field name="code" type="col"/>
                <field name="total" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- List View -->
    <record id="hr_payslip_line_view_list" model="ir.ui.view">
        <field name="name">hr.payslip.line.view.list</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <list string="Payslip Lines">
                <field name="sequence" widget="handle"/>
                <field name="employee_id"/>
                <field name="slip_id"/>
                <field name="contract_id"/>
                <field name="salary_rule_id"/>
                <field name="category_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="rate"/>
                <field name="amount"/>
                <field name="quantity"/>
                <field name="total"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="hr_payslip_line_view_search" model="ir.ui.view">
        <field name="name">hr.payslip.line.view.search</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <search string="Search Payslip Lines">
                <field name="employee_id"/>
                <field name="code"/>
                <field name="contract_id"/>
                <group>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Code" name="group_by_code" context="{'group_by': 'code'}"/>
                    <filter string="Contract" name="group_by_contract" context="{'group_by': 'contract_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_payslip_line_report" model="ir.actions.act_window">
        <field name="name">Payslip Lines</field>
        <field name="res_model">hr.payslip.line</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="hr_payslip_line_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No payslip lines found.
            </p>
        </field>
    </record>
</odoo>
