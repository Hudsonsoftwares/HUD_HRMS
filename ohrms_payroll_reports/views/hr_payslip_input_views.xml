<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pivot View -->
    <record id="hr_payslip_input_view_pivot" model="ir.ui.view">
        <field name="name">hr.payslip.input.view.pivot</field>
        <field name="model">hr.payslip.input</field>
        <field name="arch" type="xml">
            <pivot string="Payslip Inputs Analysis">
                <field name="employee_id" type="row"/>
                <field name="code" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="hr_payslip_input_view_graph" model="ir.ui.view">
        <field name="name">hr.payslip.input.view.graph</field>
        <field name="model">hr.payslip.input</field>
        <field name="arch" type="xml">
            <graph string="Payslip Inputs Analysis" type="bar">
                <field name="employee_id" type="row"/>
                <field name="code" type="col"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- List View -->
    <record id="hr_payslip_input_view_list" model="ir.ui.view">
        <field name="name">hr.payslip.input.view.list</field>
        <field name="model">hr.payslip.input</field>
        <field name="arch" type="xml">
            <list string="Payslip Other Inputs">
                <field name="sequence" widget="handle"/>
                <field name="payslip_id"/>
                <field name="contract_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="amount"/>
                <field name="date_from"/>
                <field name="date_to"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="hr_payslip_input_view_search" model="ir.ui.view">
        <field name="name">hr.payslip.input.view.search</field>
        <field name="model">hr.payslip.input</field>
        <field name="arch" type="xml">
            <search string="Search Payslip Other Inputs">
                <field name="employee_id" string="Employee"/>
                <field name="code" string="Code"/>
                <field name="contract_id" string="Contract"/>
                <filter string="This Month" name="this_month"
                        domain="[('date_from', '&gt;=', context_today().strftime('%Y-%m-01')), ('date_from', '&lt;', (context_today() + datetime.timedelta(days=32)).strftime('%Y-%m-01'))]"/>
                <filter string="Last Month" name="last_month"
                        domain="[('date_from', '&gt;=', (context_today() - datetime.timedelta(days=31)).strftime('%Y-%m-01')), ('date_from', '&lt;', context_today().strftime('%Y-%m-01'))]"/>
                <filter string="This Year" name="this_year"
                        domain="[('date_from', '&gt;=', context_today().strftime('%Y-01-01')), ('date_from', '&lt;=', context_today().strftime('%Y-12-31'))]"/>
                <group>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Code" name="group_by_code" context="{'group_by': 'code'}"/>
                    <filter string="Contract" name="group_by_contract" context="{'group_by': 'contract_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_payslip_input_report" model="ir.actions.act_window">
        <field name="name">Payslip Other Inputs</field>
        <field name="res_model">hr.payslip.input</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="hr_payslip_input_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No payslip other inputs found.
            </p>
        </field>
    </record>
</odoo>
