<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_contract_template_form_view_inherit_ot_short" model="ir.ui.view">
        <field name="name">hr.version.view.form.inherit.ot.short</field>
        <field name="model">hr.version</field>
        <field name="inherit_id" ref="hr_payroll_community.hr_contract_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='allowances']" position="inside">
                <label for="overtime_rate_per_hour"/>
                <div class="o_row">
                    <field name="overtime_rate_per_hour" nolabel="1"/>
                    <span>/ hour</span>
                </div>
                <label for="shortage_deduction_rate_per_hour"/>
                <div class="o_row">
                    <field name="shortage_deduction_rate_per_hour" nolabel="1"/>
                    <span>/ hour</span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
