<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Overtime Pay Salary Rule -->
        <record id="hr_rule_overtime_pay" model="hr.salary.rule">
            <field name="name">Overtime Pay</field>
            <field name="sequence" eval="25"/>
            <field name="code">OT</field>
            <field name="category_id" ref="hr_payroll_community.ALW"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = contract.overtime_rate_per_hour
result_qty = worked_days.OVERTIME.number_of_hours if worked_days.OVERTIME else 0.0
            </field>
            <field name="appears_on_payslip" eval="True"/>
        </record>

        <!-- Shortage Deduction Salary Rule -->
        <record id="hr_rule_shortage_deduction" model="hr.salary.rule">
            <field name="name">Shortage Deduction</field>
            <field name="sequence" eval="26"/>
            <field name="code">SHORT</field>
            <field name="category_id" ref="hr_payroll_community.DED"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = -contract.shortage_deduction_rate_per_hour
result_qty = worked_days.SHORTAGE.number_of_hours if worked_days.SHORTAGE else 0.0
            </field>
            <field name="appears_on_payslip" eval="True"/>
        </record>

        <!-- Link to Base Structure -->
        <record id="hr_payroll_community.structure_base" model="hr.payroll.structure">
            <field name="rule_ids" eval="[(4, ref('hr_rule_overtime_pay')), (4, ref('hr_rule_shortage_deduction'))]"/>
        </record>
    </data>
</odoo>
