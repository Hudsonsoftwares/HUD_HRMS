<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hudson_dynamic_financial_view.DynamicFinancialReportTemplate">
        <div class="hudson-financial-report-container p-4">
            <!-- Loading Indicator -->
            <div t-if="state.loading" class="hudson-loading-overlay">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <!-- Top Header Control Bar -->
            <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom bg-white p-3 shadow-sm rounded">
                <div>
                    <h1 class="h3 mb-1 text-primary font-weight-bold" t-esc="state.reportName"/>
                    <p class="text-muted mb-0 small">Interactive On-Screen Report</p>
                </div>
                <div class="btn-group">
                    <button class="btn btn-primary" t-on-click="printPDF">
                        <i class="fa fa-print mr-1"/> Print (PDF)
                    </button>
                    <button class="btn btn-success" t-on-click="exportXLSX">
                        <i class="fa fa-file-excel-o mr-1"/> Export (XLSX)
                    </button>
                    <button class="btn btn-secondary" t-on-click="goBack">
                        <i class="fa fa-arrow-left mr-1"/> Back to Filters
                    </button>
                </div>
            </div>

            <!-- Warning Banner -->
            <div t-if="state.hasUnposted and state.showUnpostedWarning" class="alert alert-warning alert-dismissible fade show d-flex justify-content-between align-items-center mb-4 shadow-sm" role="alert">
                <div>
                    <i class="fa fa-warning mr-2 text-warning"/>
                    <strong>Unposted Entries Warning:</strong> There are unposted Journal Entries prior or included in this period.
                </div>
                <button type="button" class="btn-close" t-on-click="dismissWarning" aria-label="Close"></button>
            </div>

            <!-- Report Card/Sheet -->
            <div class="card shadow-sm hudson-report-sheet">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr class="bg-light text-muted uppercase small">
                                    <th scope="col" class="pl-4 py-3">Name</th>
                                    <th scope="col" t-if="state.debitCredit" class="text-end py-3">Debit</th>
                                    <th scope="col" t-if="state.debitCredit" class="text-end py-3">Credit</th>
                                    <th scope="col" class="text-end py-3">Balance</th>
                                    <th scope="col" t-if="state.enableFilter" class="text-end py-3">Comparison Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.reportLines" t-as="line" t-key="line.id or line.a_id">
                                    <t t-if="isLineVisible(line)">
                                        <tr t-attf-class="report-row-#{line.type} #{line.type === 'report' ? 'font-weight-bold table-active' : ''}"
                                            t-on-click="() => this.handleLineClick(line)">
                                            <!-- Name Column with Toggle Icon and Indentation -->
                                            <td class="align-middle pl-4" t-attf-style="padding-left: #{line.level * 20}px !important;">
                                                <span t-if="hasChildren(line)" t-on-click.stop="() => this.toggleCollapse(line)" class="mr-2 cursor-pointer toggle-icon">
                                                    <i t-attf-class="fa #{isCollapsed(line) ? 'fa-chevron-right' : 'fa-chevron-down'} text-muted small"/>
                                                </span>
                                                <span t-else="" class="mr-2 toggle-placeholder"/>
                                                
                                                <span class="line-name" t-esc="line.name"/>
                                                <i t-if="line.type === 'account'" class="fa fa-list-alt text-primary ml-2 drilldown-hint" title="Drill-down to Journal Items"/>
                                            </td>
                                            
                                            <!-- Debit Column -->
                                            <td t-if="state.debitCredit" class="text-end align-middle font-monospace" t-esc="formatCurrency(line.debit)"/>
                                            
                                            <!-- Credit Column -->
                                            <td t-if="state.debitCredit" class="text-end align-middle font-monospace" t-esc="formatCurrency(line.credit)"/>
                                            
                                            <!-- Balance Column -->
                                            <td class="text-end align-middle font-monospace font-weight-bold" t-esc="formatCurrency(line.balance)"/>
                                            
                                            <!-- Comparison Balance Column -->
                                            <td t-if="state.enableFilter" class="text-end align-middle font-monospace" t-esc="formatCurrency(line.balance_cmp)"/>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Drilldown Modal Dialog -->
            <div t-if="state.showModal" class="modal fade show d-block" style="background: rgba(0, 0, 0, 0.5);" tabindex="-1" role="dialog">
                <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
                    <div class="modal-content shadow-lg border-0">
                        <div class="modal-header bg-primary text-white py-3">
                            <h5 class="modal-title font-weight-bold">
                                <i class="fa fa-list-alt mr-2"/>
                                Journal Items for <t t-esc="state.drilldownAccountName"/>
                            </h5>
                            <button type="button" class="btn-close btn-close-white text-white" t-on-click="closeModal" aria-label="Close" style="background: none; border: none; font-size: 1.5rem; line-height: 1; opacity: 0.8; padding: 0;">×</button>
                        </div>
                        <div class="modal-body p-0">
                            <div class="table-responsive" style="max-height: 500px;">
                                <table class="table table-striped table-hover mb-0">
                                    <thead class="bg-light sticky-top">
                                        <tr class="text-muted small uppercase">
                                            <th class="pl-4 py-2">Date</th>
                                            <th class="py-2">Entry</th>
                                            <th class="py-2">Partner</th>
                                            <th class="py-2">Label</th>
                                            <th class="text-end py-2">Debit</th>
                                            <th class="text-end py-2">Credit</th>
                                            <th class="text-end pr-4 py-2">Balance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-if="state.drilldownLines.length === 0">
                                            <tr>
                                                <td colspan="7" class="text-center py-4 text-muted">No journal items found for this period.</td>
                                            </tr>
                                        </t>
                                        <t t-else="">
                                            <tr t-foreach="state.drilldownLines" t-as="item" t-key="item.id">
                                                <td class="align-middle pl-4" t-esc="item.date"/>
                                                <td class="align-middle">
                                                    <a href="#" class="font-weight-bold text-decoration-none" t-on-click.prevent="() => this.openJournalEntry(item.j_id)" t-esc="item.name"/>
                                                </td>
                                                <td class="align-middle" t-esc="item.partner_name"/>
                                                <td class="align-middle" t-esc="item.label"/>
                                                <td class="text-end align-middle font-monospace" t-esc="formatCurrency(item.debit)"/>
                                                <td class="text-end align-middle font-monospace" t-esc="formatCurrency(item.credit)"/>
                                                <td class="text-end pr-4 align-middle font-monospace font-weight-bold" t-esc="formatCurrency(item.balance)"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="modal-footer py-2 bg-light">
                            <button type="button" class="btn btn-secondary" t-on-click="closeModal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
