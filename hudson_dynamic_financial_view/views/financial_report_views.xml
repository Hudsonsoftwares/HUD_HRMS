<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action Declaration -->
    <record id="action_dynamic_financial_report" model="ir.actions.client">
        <field name="name">Financial Report</field>
        <field name="tag">hudson_dynamic_financial_report</field>
        <field name="target">current</field>
    </record>

    <!-- Inherit Profit and Loss / Balance Sheet Wizard View -->
    <record id="financial_report_view_form_inherit_dynamic" model="ir.ui.view">
        <field name="name">financial.report.view.form.inherit.dynamic</field>
        <field name="model">financial.report</field>
        <field name="inherit_id" ref="base_accounting_kit.financial_report_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='view_report_pdf']" position="before">
                <button name="action_view_online" string="View Online" type="object" class="btn-primary" data-hotkey="v"/>
            </xpath>
        </field>
    </record>

