<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Raw Punch Tree View -->
    <record id="view_hudson_attendance_raw_punch_tree" model="ir.ui.view">
        <field name="name">hudson.attendance.raw.punch.tree</field>
        <field name="model">hudson.attendance.raw.punch</field>
        <field name="arch" type="xml">
            <list string="Raw Punch Logs" 
                  decoration-success="state == 'processed'" 
                  decoration-danger="state == 'failed'" 
                  decoration-warning="state == 'unmapped'" 
                  decoration-muted="state == 'duplicate'"
                  decoration-info="state == 'new'">
                <field name="employee_code"/>
                <field name="punch_time"/>
                <field name="punch_type"/>
                <field name="device_id"/>
                <field name="external_uid"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'processed'" 
                       decoration-danger="state == 'failed'" 
                       decoration-warning="state == 'unmapped'" 
                       decoration-muted="state == 'duplicate'"
                       decoration-info="state == 'new'"/>
                <field name="error_message" optional="show"/>
                <field name="hr_attendance_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Raw Punch Form View -->
    <record id="view_hudson_attendance_raw_punch_form" model="ir.ui.view">
        <field name="name">hudson.attendance.raw.punch.form</field>
        <field name="model">hudson.attendance.raw.punch</field>
        <field name="arch" type="xml">
            <form string="Raw Punch Log">
                <header>
                    <button name="action_process_punch" 
                            string="Process Punch" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="state in ('processed', 'duplicate')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,processed,failed,unmapped"/>
                </header>
                <sheet>
                    <group>
                        <group name="punch_details" string="Punch Details">
                            <field name="employee_code" readonly="state == 'processed'"/>
                            <field name="punch_time" readonly="state == 'processed'"/>
                            <field name="punch_type" readonly="state == 'processed'"/>
                            <field name="source_timezone" readonly="state == 'processed'"/>
                            <field name="external_uid" readonly="state == 'processed'"/>
                        </group>
                        <group name="audit_info" string="Metadata &amp; Target">
                            <field name="device_id" readonly="state == 'processed'"/>
                            <field name="hr_attendance_id"/>
                        </group>
                    </group>
                    <group name="error_info" string="Processing Details" invisible="not error_message">
                        <field name="error_message" colspan="2" nolabel="1" class="text-danger"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Raw Punch Search View -->
    <record id="view_hudson_attendance_raw_punch_search" model="ir.ui.view">
        <field name="name">hudson.attendance.raw.punch.search</field>
        <field name="model">hudson.attendance.raw.punch</field>
        <field name="arch" type="xml">
            <search string="Search Raw Punches">
                <field name="employee_code"/>
                <field name="external_uid"/>
                <field name="device_id"/>
                
                <separator/>
                <filter string="New" name="state_new" domain="[('state', '=', 'new')]"/>
                <filter string="Processed" name="state_processed" domain="[('state', '=', 'processed')]"/>
                <filter string="Failed" name="state_failed" domain="[('state', '=', 'failed')]"/>
                <filter string="Duplicate" name="state_duplicate" domain="[('state', '=', 'duplicate')]"/>
                <filter string="Unmapped" name="state_unmapped" domain="[('state', '=', 'unmapped')]"/>
                
                <group>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Punch Type" name="group_punch_type" context="{'group_by': 'punch_type'}"/>
                    <filter string="Device" name="group_device" context="{'group_by': 'device_id'}"/>
                    <filter string="Employee Code" name="group_employee" context="{'group_by': 'employee_code'}"/>
                    <filter string="Punch Date" name="group_punch_date" context="{'group_by': 'punch_time:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: All Raw Punches -->
    <record id="action_hudson_attendance_raw_punch_all" model="ir.actions.act_window">
        <field name="name">All Raw Punches</field>
        <field name="res_model">hudson.attendance.raw.punch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hudson_attendance_raw_punch_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No raw punch logs found.
            </p>
            <p>
                All biometric devices, Webhooks, and REST APIs write to this log canonical format.
            </p>
        </field>
    </record>

    <!-- Action: Unmapped Raw Punches (Queue) -->
    <record id="action_hudson_attendance_raw_punch_unmapped" model="ir.actions.act_window">
        <field name="name">Unmapped Punches</field>
        <field name="res_model">hudson.attendance.raw.punch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hudson_attendance_raw_punch_search"/>
        <field name="domain">[('state', '=', 'unmapped')]</field>
        <field name="context">{'search_default_state_unmapped': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Great! No unmapped punches.
            </p>
            <p>
                Punches surface here if the external employee code does not match any registered employee.
            </p>
        </field>
    </record>

    <!-- Action: Failed Raw Punches (Queue) -->
    <record id="action_hudson_attendance_raw_punch_failed" model="ir.actions.act_window">
        <field name="name">Failed Punches</field>
        <field name="res_model">hudson.attendance.raw.punch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hudson_attendance_raw_punch_search"/>
        <field name="domain">[('state', '=', 'failed')]</field>
        <field name="context">{'search_default_state_failed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No failed punches!
            </p>
            <p>
                Punches surface here if they violate attendance constraints, like check-in ordering.
            </p>
        </field>
    </record>
</odoo>
