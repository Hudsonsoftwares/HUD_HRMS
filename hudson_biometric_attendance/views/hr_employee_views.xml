<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_biometric" model="ir.ui.view">
        <field name="name">hr.employee.form.biometric</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="biometric_code" placeholder="e.g. 1004" groups="hudson_biometric_attendance.group_biometric_attendance_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
