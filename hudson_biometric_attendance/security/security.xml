<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="privilege_biometric_attendance" model="res.groups.privilege">
            <field name="name">Biometric Attendance</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="sequence">30</field>
        </record>

        <record id="group_biometric_attendance_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_biometric_attendance"/>
            <field name="implied_ids" eval="[(4, ref('hr_attendance.group_hr_attendance_user'))]"/>
        </record>

        <record id="group_biometric_attendance_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="privilege_biometric_attendance"/>
            <field name="implied_ids" eval="[(4, ref('group_biometric_attendance_user')), (4, ref('hr_attendance.group_hr_attendance_manager'))]"/>
        </record>
    </data>
</odoo>
