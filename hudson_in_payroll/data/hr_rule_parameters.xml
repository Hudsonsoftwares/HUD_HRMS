<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        STATUTORY EPF / EPS / EDLI RULE PARAMETERS DATA:
        All statutory rates, percentages, wage ceilings, and admin charges are stored with their historical gazette/notification effective dates.
        noupdate="0" during initial setup ensures full parameter records are loaded cleanly.
    -->
    <data noupdate="0">
        <!-- 1. PF: EPF Rate (12%) -->
        <record id="hds_in_epf_rate" model="hr.rule.parameter">
            <field name="name">PF: EPF Rate</field>
            <field name="code">hds_in_epf_rate</field>
            <field name="category">rate</field>
            <field name="description">Statutory Employee Provident Fund (EPF) contribution rate percentage for employee and employer. Statutory basis: EPF Scheme 1952 Paragraph 29.</field>
        </record>
        <record id="hds_in_epf_rate_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_epf_rate"/>
            <field name="date_from">2014-09-01</field>
            <field name="parameter_value">12</field>
            <field name="description">EPFO Gazette Notification G.S.R. 608(E) effective 01-Sep-2014.</field>
        </record>

        <!-- 2. PF: EPS Rate (8.33%) -->
        <record id="hds_in_eps_rate" model="hr.rule.parameter">
            <field name="name">PF: EPS Rate</field>
            <field name="code">hds_in_eps_rate</field>
            <field name="category">rate</field>
            <field name="description">Statutory Employee Pension Scheme (EPS) contribution rate percentage allocated from employer PF contribution. Statutory basis: EPS Scheme 1995 Paragraph 3(1).</field>
        </record>
        <record id="hds_in_eps_rate_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_eps_rate"/>
            <field name="date_from">2014-09-01</field>
            <field name="parameter_value">8.33</field>
            <field name="description">EPFO Gazette Notification G.S.R. 609(E) effective 01-Sep-2014.</field>
        </record>

        <!-- 3. PF: EPS Wage Ceiling (15,000) -->
        <record id="hds_in_eps_wage_ceiling" model="hr.rule.parameter">
            <field name="name">PF: EPS Wage Ceiling</field>
            <field name="code">hds_in_eps_wage_ceiling</field>
            <field name="category">ceiling</field>
            <field name="description">Statutory monthly wage ceiling limit for Employee Pension Scheme (EPS) contribution calculation. Statutory basis: EPS Scheme 1995 Paragraph 3(1) Amendment.</field>
        </record>
        <record id="hds_in_eps_wage_ceiling_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_eps_wage_ceiling"/>
            <field name="date_from">2014-09-01</field>
            <field name="parameter_value">15000</field>
            <field name="description">EPFO Gazette Notification G.S.R. 609(E) raised pensionable wage ceiling from INR 6,500 to INR 15,000 w.e.f. 01-Sep-2014.</field>
        </record>

        <!-- 4. PF: PF Wage Ceiling (15,000) -->
        <record id="hds_in_pf_wage_ceiling" model="hr.rule.parameter">
            <field name="name">PF: PF Wage Ceiling</field>
            <field name="code">hds_in_pf_wage_ceiling</field>
            <field name="category">ceiling</field>
            <field name="description">Statutory monthly wage ceiling limit for Provident Fund contribution. Statutory basis: EPF Scheme 1952 Paragraph 26A.</field>
        </record>
        <record id="hds_in_pf_wage_ceiling_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_pf_wage_ceiling"/>
            <field name="date_from">2014-09-01</field>
            <field name="parameter_value">15000</field>
            <field name="description">EPFO Gazette Notification G.S.R. 608(E) raised statutory PF wage ceiling from INR 6,500 to INR 15,000 w.e.f. 01-Sep-2014.</field>
        </record>

        <!-- 5. PF: EDLI Rate (0.5%) -->
        <record id="hds_in_edli_rate" model="hr.rule.parameter">
            <field name="name">PF: EDLI Rate</field>
            <field name="code">hds_in_edli_rate</field>
            <field name="category">rate</field>
            <field name="description">Statutory Employee Deposit Linked Insurance (EDLI) employer contribution rate percentage (0.5%). Statutory basis: EDLI Scheme 1976 Paragraph 8.</field>
        </record>
        <record id="hds_in_edli_rate_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_edli_rate"/>
            <field name="date_from">2018-06-01</field>
            <field name="parameter_value">0.5</field>
            <field name="description">EPFO Notification S.O. 2013(E) effective 01-Jun-2018 establishing EDLI contribution rate at 0.5%.</field>
        </record>

        <!-- 6. PF: EDLI Wage Ceiling (15,000) -->
        <record id="hds_in_edli_wage_ceiling" model="hr.rule.parameter">
            <field name="name">PF: EDLI Wage Ceiling</field>
            <field name="code">hds_in_edli_wage_ceiling</field>
            <field name="category">ceiling</field>
            <field name="description">Statutory monthly wage ceiling limit for EDLI employer contribution calculation. Statutory basis: EDLI Scheme 1976 Paragraph 8(1).</field>
        </record>
        <record id="hds_in_edli_wage_ceiling_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_edli_wage_ceiling"/>
            <field name="date_from">2014-09-01</field>
            <field name="parameter_value">15000</field>
            <field name="description">EPFO Gazette Notification S.O. 2259(E) raised EDLI wage ceiling to INR 15,000 w.e.f. 01-Sep-2014.</field>
        </record>

        <!-- 7. PF: EPF Admin Charge Rate (0.5%) -->
        <record id="hds_in_epf_admin_charge_rate" model="hr.rule.parameter">
            <field name="name">PF: EPF Admin Charge Rate</field>
            <field name="code">hds_in_epf_admin_charge_rate</field>
            <field name="category">admin</field>
            <field name="description">Employer administrative charges rate percentage for EPF Scheme (Account No. 2). Statutory basis: EPF Scheme 1952 Paragraph 38.</field>
        </record>
        <record id="hds_in_epf_admin_charge_rate_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_epf_admin_charge_rate"/>
            <field name="date_from">2018-06-01</field>
            <field name="parameter_value">0.5</field>
            <field name="description">EPFO Notification S.O. 2012(E) effective 01-Jun-2018 reducing EPF admin charge to 0.5% (subject to min INR 500/month).</field>
        </record>

        <!-- 8. PF: EDLI Admin Charge Rate (0%) -->
        <record id="hds_in_edli_admin_charge_rate" model="hr.rule.parameter">
            <field name="name">PF: EDLI Admin Charge Rate</field>
            <field name="code">hds_in_edli_admin_charge_rate</field>
            <field name="category">admin</field>
            <field name="description">Employer administrative charges rate percentage for EDLI Scheme (Account No. 22). Statutory basis: EDLI Scheme 1976 Paragraph 8(4).</field>
        </record>
        <record id="hds_in_edli_admin_charge_rate_val_1" model="hr.rule.parameter.value">
            <field name="parameter_id" ref="hds_in_edli_admin_charge_rate"/>
            <field name="date_from">2017-04-01</field>
            <field name="parameter_value">0</field>
            <field name="description">EPFO Notification S.O. 1091(E) effective 01-Apr-2017 waiving EDLI admin charges (stored as 0, not hardcoded in code).</field>
        </record>
    </data>
</odoo>
