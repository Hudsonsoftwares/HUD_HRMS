<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hds_in_res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hds.in.payroll</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_payroll_community.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@data-key='hr_payroll_community']" position="inside">
                <field name="hds_in_is_india_company" invisible="1"/>
                <div class="hds_in_payroll_localization_container" invisible="not hds_in_is_india_company">
                    <h2 class="mt32">Indian Localization</h2>
                    <div class="row mt16 o_settings_container">
                        <!-- Left Column: EPF -->
                        <div class="col-12 col-lg-6 o_setting_box" id="hds_in_epf_setting">
                            <div class="o_setting_left_pane">
                                <field name="hds_in_epf_applicable"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="hds_in_epf_applicable" string="Employee Provident Fund (EPF)" class="fw-bold"/>
                                <div class="text-muted">
                                    Enable this to automatically calculate and deduct provident fund contributions from both employer and employee.
                                </div>
                                <div class="content-group mt8" invisible="not hds_in_epf_applicable">
                                    <div class="row mt8">
                                        <label for="hds_in_epf_employer_id" class="col-lg-5 o_light_label"/>
                                        <field name="hds_in_epf_employer_id" placeholder="e.g. MH/BAN/0012345/000"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column: EDLI -->
                        <div class="col-12 col-lg-6 o_setting_box" id="hds_in_edli_setting">
                            <div class="o_setting_left_pane">
                                <field name="hds_in_edli_applicable"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="hds_in_edli_applicable" string="Employee Deposit Linked Insurance (EDLI)" class="fw-bold"/>
                                <div class="text-muted">
                                    Enable this to calculate the employer's EDLI contribution as part of statutory PF compliance.
                                </div>
                                <div class="content-group mt8" invisible="not hds_in_edli_applicable">
                                    <div class="row mt8">
                                        <label for="hds_in_edli_registration_number" class="col-lg-5 o_light_label"/>
                                        <field name="hds_in_edli_registration_number" placeholder="e.g. EDLI/12345/REG"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Left Column: EPS -->
                        <div class="col-12 col-lg-6 o_setting_box" id="hds_in_eps_setting">
                            <div class="o_setting_left_pane">
                                <field name="hds_in_eps_applicable"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="hds_in_eps_applicable" string="Employee Pension Scheme (EPS)" class="fw-bold"/>
                                <div class="text-muted">
                                    Enable this to automatically calculate and allocate pension contributions from the employer's PF contribution.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
