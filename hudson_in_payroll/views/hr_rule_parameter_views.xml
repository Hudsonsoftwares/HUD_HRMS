<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rule Parameter Value List View -->
    <record id="hds_in_hr_rule_parameter_value_view_tree" model="ir.ui.view">
        <field name="name">hr.rule.parameter.value.view.tree</field>
        <field name="model">hr.rule.parameter.value</field>
        <field name="arch" type="xml">
            <list editable="bottom" default_order="date_from desc">
                <field name="date_from" string="From"/>
                <field name="parameter_value" string="Parameter Value"/>
                <field name="description" string="Notification / Notes"/>
            </list>
        </field>
    </record>

    <!-- Rule Parameter Form View (Stock Odoo Layout) -->
    <record id="hds_in_hr_rule_parameter_view_form" model="ir.ui.view">
        <field name="name">hr.rule.parameter.view.form</field>
        <field name="model">hr.rule.parameter</field>
        <field name="arch" type="xml">
            <form string="Rule Parameter">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. PF: EPF Rate"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" help="Code used in salary rules to reference this parameter value."/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="current_value" readonly="1"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Note a description of your parameter, when it's used, how is it computed, what's the source, ..."/>
                    </group>
                    <notebook>
                        <page string="History" name="history">
                            <field name="parameter_version_ids" context="{'tree_view_ref': 'hudson_in_payroll.hds_in_hr_rule_parameter_value_view_tree'}">
                                <list editable="bottom" default_order="date_from desc">
                                    <field name="date_from" string="From"/>
                                    <field name="parameter_value" string="Parameter Value"/>
                                    <field name="description" string="Notification / Notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Rule Parameter Search View -->
    <record id="hds_in_hr_rule_parameter_view_search" model="ir.ui.view">
        <field name="name">hr.rule.parameter.search</field>
        <field name="model">hr.rule.parameter</field>
        <field name="arch" type="xml">
            <search string="Search Rule Parameters">
                <field name="name" string="Parameter" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="category"/>
                <separator/>
                <filter string="Statutory Rates" name="filter_rates" domain="[('category', '=', 'rate')]"/>
                <filter string="Wage Ceilings" name="filter_ceilings" domain="[('category', '=', 'ceiling')]"/>
                <filter string="Admin Charges" name="filter_admin" domain="[('category', '=', 'admin')]"/>
                <separator/>
                <group>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Rule Parameter List View -->
    <record id="hds_in_hr_rule_parameter_view_tree" model="ir.ui.view">
        <field name="name">hr.rule.parameter.view.list</field>
        <field name="model">hr.rule.parameter</field>
        <field name="arch" type="xml">
            <list string="Rule Parameters">
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="current_value"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Rule Parameter Window Action -->
    <record id="hds_in_action_hr_rule_parameter" model="ir.actions.act_window">
        <field name="name">Rule Parameters</field>
        <field name="res_model">hr.rule.parameter</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hds_in_hr_rule_parameter_view_search"/>
        <field name="context">{'search_default_group_by_category': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new statutory rule parameter!
            </p>
            <p>
                Rule parameters store effective-dated statutory rates, wage ceilings, and government limits for payroll calculations.
            </p>
        </field>
    </record>

    <!-- Rule Parameter Menuitem under Payroll -> Configuration -->
    <menuitem id="hds_in_menu_hr_rule_parameter"
              name="Rule Parameters"
              parent="hr_payroll_community.menu_hr_payroll_community_configuration"
              sequence="25"
              action="hds_in_action_hr_rule_parameter"
              groups="hr_payroll_community.group_hr_payroll_community_manager"/>
</odoo>
