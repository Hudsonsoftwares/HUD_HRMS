<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="hr_payroll_community.hr_rule_unpaid" model="hr.salary.rule">
            <field name="name">Unpaid Leave Deduction</field>
            <field name="amount_python_compute">
result = -(worked_days.UNPAID.number_of_days if worked_days.UNPAID else 0.0) * (contract.hourly_rate * contract.standard_hours_per_day)
            </field>
        </record>

        <!-- Ensure Unpaid Leave Deduction is linked to the Base structure -->
        <record id="hr_payroll_community.structure_base" model="hr.payroll.structure">
            <field name="rule_ids" eval="[(4, ref('hr_payroll_community.hr_rule_unpaid'))]"/>
        </record>
    </data>
</odoo>
